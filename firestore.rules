rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validCity(city) {
      return city == '' || city in ['bangalore', 'pune', 'hyderabad', 'chennai', 'mumbai', 'delhi'];
    }

    function validLocality(locality) {
      return locality == '' || locality in [
        'whitefield', 'hsr', 'koramangala', 'electronic_city', 'indiranagar',
        'baner', 'hinjewadi', 'kothrud', 'viman_nagar',
        'hitec_city', 'gachibowli', 'kukatpally', 'madhapur',
        'omr', 'anna_nagar', 't_nagar',
        'andheri', 'bkc', 'powai',
        'gurgaon', 'noida', 'cp'
      ];
    }

    function validCategory(category) {
      return category == '' || category in ['work', 'life', 'relationship', 'college', 'traffic', 'rent', 'startup', 'food'];
    }

    function validImageUrl(url) {
      return url is string
        && url.size() > 0
        && url.size() <= 2048
        && url.matches('https://.*')
        && (
          url.matches('https://[a-zA-Z0-9.-]+\\.s3\\.amazonaws\\.com/.*')
          || url.matches('https://[a-zA-Z0-9.-]+\\.s3\\.[a-z0-9-]+\\.amazonaws\\.com/.*')
          || url.matches('https://[a-zA-Z0-9.-]+\\.cloudfront\\.net/.*')
          || url.matches('https://citysnap\\.app/.*')
        );
    }

    function validImageUrls(urls) {
      return urls is list
        && urls.size() <= 4
        && (urls.size() == 0 || (
          validImageUrl(urls[0])
          && (urls.size() < 2 || validImageUrl(urls[1]))
          && (urls.size() < 3 || validImageUrl(urls[2]))
          && (urls.size() < 4 || validImageUrl(urls[3]))
        ));
    }

    function hasValidImages(data) {
      return data.keys().hasAny(['imageUrls'])
        && data.imageUrls is list
        && data.imageUrls.size() > 0
        && data.imageUrls.size() <= 4;
    }

    function validPostContent(data) {
      let pt = data.get('postType', 'snap');
      let maxLen = pt == 'note' ? 800 : 250;
      return (data.text is string && data.text.size() > 0 && data.text.size() <= maxLen)
        || (pt == 'snap' && hasValidImages(data));
    }

    function validPostType(data) {
      let pt = data.get('postType', 'snap');
      return pt == 'snap' || pt == 'note';
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function validUserName(data) {
      return data.name is string
        && data.name.size() > 0
        && data.name.size() <= 60;
    }

    function validUserEmail(data) {
      return !data.keys().hasAny(['email'])
        || (data.email is string && data.email.size() <= 320);
    }

    function validUserPhotoUrl(data) {
      return !data.keys().hasAny(['photoUrl'])
        || (data.photoUrl is string && data.photoUrl.size() <= 2048);
    }

    function validUserReferralCode(data) {
      return !data.keys().hasAny(['referralCode'])
        || (data.referralCode is string && data.referralCode.size() <= 64);
    }

    function isBlocked(uidA, uidB) {
      return exists(/databases/$(database)/documents/users/$(uidA)/blocked/$(uidB))
        || exists(/databases/$(database)/documents/users/$(uidB)/blocked/$(uidA));
    }

    function validUserCreateKeys(data) {
      return data.keys().hasOnly([
        'uid', 'name', 'email', 'city', 'locality', 'referralCode',
        'photoUrl', 'createdAt', 'notifyFeels', 'notifyComments',
        'notifyPrompts', 'notifyMessages'
      ]);
    }

    function validUserCreate(data, uid) {
      return validUserCreateKeys(data)
        && data.uid == uid
        && validUserName(data)
        && validUserEmail(data)
        && validUserPhotoUrl(data)
        && validUserReferralCode(data)
        && validCity(data.get('city', ''))
        && validLocality(data.get('locality', ''))
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is int)
        && (!data.keys().hasAny(['notifyFeels']) || data.notifyFeels is bool)
        && (!data.keys().hasAny(['notifyComments']) || data.notifyComments is bool)
        && (!data.keys().hasAny(['notifyPrompts']) || data.notifyPrompts is bool)
        && (!data.keys().hasAny(['notifyMessages']) || data.notifyMessages is bool);
    }

    function keepsServerUserFields() {
      return request.resource.data.get('isPremium', false) == resource.data.get('isPremium', false)
        && request.resource.data.get('badges', []) == resource.data.get('badges', [])
        && request.resource.data.get('referralCount', 0) == resource.data.get('referralCount', 0)
        && request.resource.data.get('voiceScore', 0) == resource.data.get('voiceScore', 0)
        && request.resource.data.get('totalFeelsReceived', 0) == resource.data.get('totalFeelsReceived', 0)
        && request.resource.data.get('savedThoughtIds', []) == resource.data.get('savedThoughtIds', []);
    }

    function validUserUpdate(uid) {
      return request.resource.data.uid == uid
        && keepsServerUserFields()
        && (
          (changedKeys().hasOnly(['city', 'locality'])
            && validCity(request.resource.data.get('city', ''))
            && validLocality(request.resource.data.get('locality', '')))
          || changedKeys().hasOnly(['postStreak', 'lastPostDate'])
          || (changedKeys().hasOnly(['fcmToken'])
            && request.resource.data.fcmToken is string
            && request.resource.data.fcmToken.size() <= 4096)
          || (changedKeys().hasOnly(['name']) && validUserName(request.resource.data))
          || (changedKeys().hasOnly(['photoUrl']) && validUserPhotoUrl(request.resource.data))
          || (changedKeys().hasOnly(['notifyFeels', 'notifyComments', 'notifyPrompts'])
            && request.resource.data.notifyFeels is bool
            && request.resource.data.notifyComments is bool
            && request.resource.data.notifyPrompts is bool)
          || (changedKeys().hasOnly(['notifyMessages'])
            && request.resource.data.notifyMessages is bool)
          || (changedKeys().hasOnly(['notifyFeels', 'notifyComments', 'notifyPrompts', 'notifyMessages'])
            && request.resource.data.notifyFeels is bool
            && request.resource.data.notifyComments is bool
            && request.resource.data.notifyPrompts is bool
            && request.resource.data.notifyMessages is bool)
          || (changedKeys().hasOnly(['referralCode'])
            && resource.data.get('referralCode', '') == ''
            && validUserReferralCode(request.resource.data))
          || (changedKeys().hasOnly(['referredBy'])
            && resource.data.get('referredBy', '') == ''
            && request.resource.data.referredBy is string
            && request.resource.data.referredBy.size() > 0
            && request.resource.data.referredBy != uid)
        );
    }

    function validThoughtCreateKeys(data) {
      return data.keys().hasAll([
        'id', 'text', 'feelCount', 'commentCount', 'shareCount',
        'authorId', 'authorName', 'authorPhotoUrl', 'city', 'locality',
        'category', 'postType', 'trendingRank', 'isSponsored',
        'sponsorLabel', 'sponsorUrl', 'imageUrls', 'imageCount',
        'createdAt'
      ]) && data.keys().size() <= 19;
    }

    match /users/{uid} {
      allow read: if isUser(uid);
      allow create: if isUser(uid)
        && validUserCreate(request.resource.data, uid);
      allow update: if isUser(uid)
        && validUserUpdate(uid);
      allow delete: if isUser(uid);

      match /blocked/{blockedUid} {
        allow read, create, delete: if isUser(uid);
        allow update: if false;
      }

      match /hidden/{thoughtId} {
        allow read, create, delete: if isUser(uid);
        allow update: if false;
      }

      match /referrals/{referredUid} {
        allow read: if isUser(uid);
        allow create: if isSignedIn() && request.auth.uid == referredUid;
        allow update: if false;
        allow delete: if isUser(uid);
      }

      match /saved/{thoughtId} {
        allow read, create: if isUser(uid)
          && get(/databases/$(database)/documents/users/$(uid)).data.get('isPremium', false) == true;
        allow delete: if isUser(uid);
        allow update: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isUser(uid);
        allow update: if isUser(uid)
          && changedKeys().hasOnly(['read'])
          && request.resource.data.read is bool;
        allow delete: if isUser(uid);
        allow create: if false;
      }

      match /conversation_meta/{conversationId} {
        function validConversationMetaWrite() {
          return request.resource.data.otherUserId is string
            && request.resource.data.otherUserId.size() > 0
            && request.resource.data.lastMessageText is string
            && request.resource.data.lastMessageText.size() <= 120
            && request.resource.data.lastMessageAt is int
            && request.resource.data.unreadCount is number
            && request.resource.data.unreadCount >= 0
            && request.resource.data.hidden is bool;
        }

        function isConversationParticipantWriter() {
          return isSignedIn()
            && exists(/databases/$(database)/documents/conversations/$(conversationId))
            && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
            && request.resource.data.otherUserId == request.auth.uid;
        }

        allow read: if isUser(uid);
        allow create, update: if (isUser(uid) && validConversationMetaWrite())
          || (isConversationParticipantWriter() && validConversationMetaWrite());
        allow update: if isUser(uid)
          && (
            (changedKeys().hasOnly(['unreadCount'])
              && request.resource.data.unreadCount == 0
              && request.resource.data.unreadCount is number)
            || (changedKeys().hasOnly(['hidden'])
              && request.resource.data.hidden is bool)
            || (changedKeys().hasOnly(['unreadCount', 'hidden'])
              && request.resource.data.unreadCount == 0
              && request.resource.data.hidden is bool)
            || (
              changedKeys().hasOnly(['otherUserId', 'lastMessageText', 'lastMessageAt', 'unreadCount', 'hidden'])
              && validConversationMetaWrite()
            )
          );
        allow delete: if isUser(uid);
      }

      match /rate_limits/{docId} {
        allow read, write: if false;
      }
    }

    match /public_profiles/{uid} {
      allow read: if true;
      allow write: if false;
    }

    match /referral_codes/{code} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /sponsor_leads/{leadId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.businessName is string
        && request.resource.data.email is string;
      allow read, update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /prompts/{city}/daily/{date} {
      allow read: if true;
      allow write: if false;
    }

    match /city_mood/{city}/weekly/{weekId} {
      allow read: if true;
      allow write: if false;
    }

    match /conversations/{conversationId} {
      function conversationParticipants() {
        return get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }

      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds[0] is string
        && request.resource.data.participantIds[1] is string
        && request.resource.data.participantIds[0] < request.resource.data.participantIds[1]
        && conversationId == request.resource.data.participantIds[0] + '_' + request.resource.data.participantIds[1]
        && !isBlocked(
          request.resource.data.participantIds[0],
          request.resource.data.participantIds[1]
        );

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds
        && changedKeys().hasOnly(['lastMessageText', 'lastMessageAt', 'lastSenderId'])
        && request.resource.data.lastMessageText is string
        && request.resource.data.lastMessageText.size() > 0
        && request.resource.data.lastMessageText.size() <= 120
        && request.resource.data.lastSenderId == request.auth.uid
        && request.resource.data.lastMessageAt is int;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in conversationParticipants();

        allow create: if isSignedIn()
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in conversationParticipants()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt is int
          && !isBlocked(conversationParticipants()[0], conversationParticipants()[1]);

        allow update: if isSignedIn()
          && request.auth.uid in conversationParticipants()
          && changedKeys().hasOnly(['readBy'])
          && request.resource.data.readBy[request.auth.uid] is int;

        allow delete: if false;
      }
    }

    match /thoughts/{thoughtId} {
      function feelCountDeltaValid() {
        let prev = resource.data.get('feelCount', 0);
        let next = request.resource.data.feelCount;
        return changedKeys().hasOnly(['feelCount'])
          && next is number
          && next >= 0
          && (next == prev + 1 || next == prev - 1);
      }

      function commentCountDeltaValid() {
        let prev = resource.data.get('commentCount', 0);
        let next = request.resource.data.commentCount;
        return changedKeys().hasOnly(['commentCount'])
          && next is number
          && next >= 0
          && (next == prev + 1 || next == prev - 1);
      }

      allow read: if true;

      allow create: if isSignedIn()
        && validThoughtCreateKeys(request.resource.data)
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.id == thoughtId
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 60
        && request.resource.data.get('authorPhotoUrl', '') is string
        && request.resource.data.get('authorPhotoUrl', '').size() <= 2048
        && validPostContent(request.resource.data)
        && validPostType(request.resource.data)
        && (!request.resource.data.keys().hasAny(['text'])
          || (request.resource.data.text is string
            && request.resource.data.text.size() <= (request.resource.data.get('postType', 'snap') == 'note' ? 800 : 250)))
        && (request.resource.data.get('postType', 'snap') != 'note'
          || request.resource.data.get('category', '') != '')
        && (!request.resource.data.keys().hasAny(['postType'])
          || request.resource.data.postType == 'snap'
          || request.resource.data.postType == 'note')
        && (!request.resource.data.keys().hasAny(['sponsorUrl'])
          || request.resource.data.get('sponsorUrl', '') == '')
        && (!request.resource.data.keys().hasAny(['imageUrls'])
          || validImageUrls(request.resource.data.imageUrls))
        && (!request.resource.data.keys().hasAny(['imageCount'])
          || (request.resource.data.imageCount is int
            && request.resource.data.imageCount == request.resource.data.get('imageUrls', []).size()))
        && request.resource.data.feelCount == 0
        && request.resource.data.get('commentCount', 0) == 0
        && request.resource.data.get('shareCount', 0) == 0
        && request.resource.data.get('trendingRank', 0) == 0
        && request.resource.data.createdAt is int
        && request.resource.data.get('isSponsored', false) == false
        && request.resource.data.get('sponsorLabel', '') == ''
        && validCity(request.resource.data.get('city', ''))
        && validLocality(request.resource.data.get('locality', ''))
        && validCategory(request.resource.data.get('category', ''));

      allow update: if isSignedIn()
        && (
          (
            resource.data.authorId == request.auth.uid
            && changedKeys().hasOnly(['text'])
            && request.resource.data.text is string
            && request.resource.data.text.size() <= 250
            && (
              request.resource.data.text.size() > 0
              || resource.data.get('imageUrls', []).size() > 0
            )
          )
          || feelCountDeltaValid()
          || commentCountDeltaValid()
        );

      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && exists(/databases/$(database)/documents/thoughts/$(thoughtId))
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid
          && changedKeys().hasOnly(['text'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow delete: if isSignedIn()
          && (
            resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/thoughts/$(thoughtId)).data.authorId == request.auth.uid
          );
      }

      match /feels/{uid} {
        allow read: if isSignedIn();
        allow create: if isUser(uid)
          && exists(/databases/$(database)/documents/thoughts/$(thoughtId))
          && request.resource.data.uid == uid;
        allow delete: if isUser(uid)
          || get(/databases/$(database)/documents/thoughts/$(thoughtId)).data.authorId == request.auth.uid;
        allow update: if false;
      }
    }
  }
}
